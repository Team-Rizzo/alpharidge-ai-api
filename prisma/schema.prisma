// Unified X Archive + Alpharidge AI Database Schema

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Twitter/X user accounts
model Account {
  id                BigInt    @id
  name              String?
  screenName        String    @map("screen_name")
  userName          String?   @map("user_name")
  location          String?
  url               String?
  description       String?
  email             String?
  protected         Boolean   @default(false)
  verified          Boolean   @default(false)
  isBlueVerified    Boolean   @default(false) @map("is_blue_verified")
  followersCount    Int       @default(0) @map("followers_count")
  followingCount    Int       @default(0) @map("following_count")
  friendsCount      Int       @default(0) @map("friends_count")
  favouritesCount   Int       @default(0) @map("favourites_count")
  statusesCount     Int       @default(0) @map("statuses_count")
  mediaCount        Int       @default(0) @map("media_count")
  createdAt         DateTime? @map("created_at") @db.Timestamptz
  profileBannerUrl  String?   @map("profile_banner_url")
  profileImageUrl   String?   @map("profile_image_url")
  canDm             Boolean   @default(false) @map("can_dm")
  canMediaTag       Boolean   @default(true) @map("can_media_tag")
  isTranslator      Boolean   @default(false) @map("is_translator")
  isAutomated       Boolean   @default(false) @map("is_automated")
  automatedBy       String?   @map("automated_by")
  possiblySensitive Boolean   @default(false) @map("possibly_sensitive")
  firstSeenAt       DateTime  @default(now()) @map("first_seen_at") @db.Timestamptz
  lastUpdatedAt     DateTime  @default(now()) @map("last_updated_at") @db.Timestamptz

  // Relations
  tweets            Tweet[]
  monitoredAccount  MonitoredAccount?
  relationships     Relationship[]

  @@index([screenName], name: "idx_accounts_screen_name")
  @@index([userName], name: "idx_accounts_user_name")
  @@map("accounts")
}

/// Accounts being actively monitored for tweets via streaming
model MonitoredAccount {
  id          Int       @id @default(autoincrement())
  screenName  String    @unique @map("screen_name")
  accountId   BigInt?   @unique @map("account_id")
  ruleId      String?   @map("rule_id")
  ruleTag     String?   @map("rule_tag")
  isActive    Boolean   @default(true) @map("is_active")
  addedAt     DateTime  @default(now()) @map("added_at") @db.Timestamptz
  lastTweetAt DateTime? @map("last_tweet_at") @db.Timestamptz

  // Relations
  account Account? @relation(fields: [accountId], references: [id])

  @@index([screenName], name: "idx_monitored_screen_name")
  @@index([isActive], name: "idx_monitored_active")
  @@map("monitored_accounts")
}

/// Accounts whose followers/followings were imported
model SourceAccount {
  id          Int      @id @default(autoincrement())
  screenName  String   @unique @map("screen_name")
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz

  @@map("source_accounts")
}

/// Follower/following relationships between accounts
model Relationship {
  id               Int      @id @default(autoincrement())
  sourceAccount    String   @map("source_account")
  targetAccountId  BigInt   @map("target_account_id")
  relationshipType String   @map("relationship_type")
  discoveredAt     DateTime @default(now()) @map("discovered_at") @db.Timestamptz

  // Relations
  targetAccount Account @relation(fields: [targetAccountId], references: [id])

  @@unique([sourceAccount, targetAccountId, relationshipType])
  @@index([sourceAccount], name: "idx_relationships_source")
  @@index([targetAccountId], name: "idx_relationships_target")
  @@index([relationshipType], name: "idx_relationships_type")
  @@map("relationships")
}

/// Main tweets storage - raw API data only (source of truth)
model Tweet {
  id                 BigInt    @id
  type               String    @default("tweet")
  url                String?
  text               String?
  source             String?
  lang               String?
  
  // Engagement metrics
  retweetCount       Int       @default(0) @map("retweet_count")
  replyCount         Int       @default(0) @map("reply_count")
  likeCount          Int       @default(0) @map("like_count")
  quoteCount         Int       @default(0) @map("quote_count")
  viewCount          Int       @default(0) @map("view_count")
  bookmarkCount      Int       @default(0) @map("bookmark_count")
  
  // Reply/conversation info
  isReply            Boolean   @default(false) @map("is_reply")
  inReplyToId        BigInt?   @map("in_reply_to_id")
  conversationId     BigInt?   @map("conversation_id")
  inReplyToUserId    BigInt?   @map("in_reply_to_user_id")
  inReplyToUsername  String?   @map("in_reply_to_username")
  
  // Author
  authorId           BigInt?   @map("author_id")
  
  // Referenced tweets
  quotedTweetId      BigInt?   @map("quoted_tweet_id")
  retweetedTweetId   BigInt?   @map("retweeted_tweet_id")
  
  // Stream rule info
  ruleId             String?   @map("rule_id")
  ruleTag            String?   @map("rule_tag")
  
  // Card and place data (stored as JSON)
  cardData           Json?     @map("card_data") @db.JsonB
  placeData          Json?     @map("place_data") @db.JsonB
  
  // Timestamps
  createdAt          DateTime? @map("created_at") @db.Timestamptz
  receivedAt         DateTime  @default(now()) @map("received_at") @db.Timestamptz

  // Relations
  author             Account?  @relation(fields: [authorId], references: [id])
  media              TweetMedia[]
  mentions           TweetMention[]
  hashtags           TweetHashtag[]
  urls               TweetUrl[]
  symbols            TweetSymbol[]
  scorings           Scoring[]
  analysis           TweetAnalysis?
  
  // Self-referencing relations
  quotedTweet        Tweet?    @relation("QuotedTweet", fields: [quotedTweetId], references: [id])
  quotedBy           Tweet[]   @relation("QuotedTweet")
  retweetedTweet     Tweet?    @relation("RetweetedTweet", fields: [retweetedTweetId], references: [id])
  retweetedBy        Tweet[]   @relation("RetweetedTweet")

  @@index([authorId], name: "idx_tweets_author")
  @@index([createdAt], name: "idx_tweets_created")
  @@index([conversationId], name: "idx_tweets_conversation")
  @@index([inReplyToId], name: "idx_tweets_in_reply_to")
  @@index([quotedTweetId], name: "idx_tweets_quoted")
  @@index([retweetedTweetId], name: "idx_tweets_retweeted")
  @@index([ruleId], name: "idx_tweets_rule")
  @@map("tweets")
}

/// Tweet analysis/sentiment results - separate from raw tweet data
/// Allows re-running analysis without modifying source tweet data
model TweetAnalysis {
  id                  Int       @id @default(autoincrement())
  tweetId             BigInt    @unique @map("tweet_id")
  
  // Sentiment analysis
  sentiment           String?   // very_bullish, bullish, neutral, bearish, very_bearish
  
  // Subnet classification (legacy — kept for backward compatibility with existing data)
  subnetId            Int?      @map("subnet_id")
  subnetName          String?   @map("subnet_name")

  // Asset classification (new — replaces subnet classification)
  assetId             Int?      @map("asset_id")
  assetSymbol         String?   @map("asset_symbol")
  
  // Content analysis
  contentType         String?   @map("content_type")
  technicalQuality    String?   @map("technical_quality")
  marketAnalysis      String?   @map("market_analysis")
  impactPotential     String?   @map("impact_potential")
  relevanceConfidence String?   @map("relevance_confidence")
  
  // Full analysis data (JSON blob)
  analysisData        Json?     @map("analysis_data") @db.JsonB

  // Miner attribution
  minerHotkey         String?   @map("miner_hotkey")

  // Timestamps
  analyzedAt          DateTime  @default(now()) @map("analyzed_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  tweet               Tweet     @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@index([sentiment], name: "idx_tweet_analysis_sentiment")
  @@index([subnetId], name: "idx_tweet_analysis_subnet")
  @@index([assetId], name: "idx_tweet_analysis_asset")
  @@index([analyzedAt], name: "idx_tweet_analysis_analyzed_at")
  @@map("tweet_analysis")
}

/// Media attachments on tweets
model TweetMedia {
  id          Int     @id @default(autoincrement())
  tweetId     BigInt  @map("tweet_id")
  mediaId     String  @map("media_id")
  mediaKey    String? @map("media_key")
  type        String? // photo, video, animated_gif
  url         String?
  mediaUrl    String? @map("media_url")
  displayUrl  String? @map("display_url")
  expandedUrl String? @map("expanded_url")
  width       Int?
  height      Int?
  durationMs  Int?    @map("duration_ms") // for video
  altText     String? @map("alt_text")

  // Relations
  tweet Tweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@unique([tweetId, mediaId])
  @@index([tweetId], name: "idx_tweet_media_tweet")
  @@index([type], name: "idx_tweet_media_type")
  @@map("tweet_media")
}

/// User mentions in tweets
model TweetMention {
  id         Int     @id @default(autoincrement())
  tweetId    BigInt  @map("tweet_id")
  userId     BigInt? @map("user_id")
  screenName String  @map("screen_name")
  name       String?
  startIndex Int?    @map("start_index")
  endIndex   Int?    @map("end_index")

  // Relations
  tweet Tweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@unique([tweetId, userId])
  @@index([tweetId], name: "idx_tweet_mentions_tweet")
  @@index([userId], name: "idx_tweet_mentions_user")
  @@index([screenName], name: "idx_tweet_mentions_screen_name")
  @@map("tweet_mentions")
}

/// Hashtags in tweets
model TweetHashtag {
  id         Int    @id @default(autoincrement())
  tweetId    BigInt @map("tweet_id")
  tag        String
  startIndex Int?   @map("start_index")
  endIndex   Int?   @map("end_index")

  // Relations
  tweet Tweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@unique([tweetId, tag])
  @@index([tweetId], name: "idx_tweet_hashtags_tweet")
  @@index([tag], name: "idx_tweet_hashtags_tag")
  @@map("tweet_hashtags")
}

/// URLs in tweets
model TweetUrl {
  id          Int     @id @default(autoincrement())
  tweetId     BigInt  @map("tweet_id")
  url         String
  expandedUrl String? @map("expanded_url")
  displayUrl  String? @map("display_url")
  startIndex  Int?    @map("start_index")
  endIndex    Int?    @map("end_index")

  // Relations
  tweet Tweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@index([tweetId], name: "idx_tweet_urls_tweet")
  @@map("tweet_urls")
}

/// Cashtags/symbols in tweets
model TweetSymbol {
  id         Int    @id @default(autoincrement())
  tweetId    BigInt @map("tweet_id")
  symbol     String
  startIndex Int?   @map("start_index")
  endIndex   Int?   @map("end_index")

  // Relations
  tweet Tweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@unique([tweetId, symbol])
  @@index([tweetId], name: "idx_tweet_symbols_tweet")
  @@index([symbol], name: "idx_tweet_symbols_symbol")
  @@map("tweet_symbols")
}

/// Log of websocket stream events received
model StreamEvent {
  id         Int      @id @default(autoincrement())
  eventType  String   @map("event_type")
  ruleId     String?  @map("rule_id")
  ruleTag    String?  @map("rule_tag")
  tweetCount Int?     @map("tweet_count")
  timestamp  BigInt?
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz
  rawPayload Json?    @map("raw_payload") @db.JsonB

  @@index([eventType], name: "idx_stream_events_type")
  @@index([receivedAt], name: "idx_stream_events_received")
  @@map("stream_events")
}

/// Scoring records for tweet validation
model Scoring {
  id              Int       @id @default(autoincrement())
  tweetId         BigInt    @map("tweet_id")
  status          String    @default("pending") // pending, in_progress, completed
  startTime       DateTime? @map("start_time") @db.Timestamptz
  validatorHotkey String?   @map("validator_hotkey")
  score           Float?
  epoch           Int?      @map("epoch")
  minerHotkey     String?   @map("miner_hotkey")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  tweet Tweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)

  @@index([tweetId], name: "idx_scoring_tweet")
  @@index([status], name: "idx_scoring_status")
  @@index([validatorHotkey], name: "idx_scoring_validator")
  @@index([status, startTime], name: "idx_scoring_status_start_time")
  @@map("scoring")
}

/// Validator penalties
model Penalty {
  id        Int      @id @default(autoincrement())
  hotkey    String
  reason    String
  timestamp DateTime @default(now()) @db.Timestamptz

  @@index([hotkey], name: "idx_penalties_hotkey")
  @@index([timestamp], name: "idx_penalties_timestamp")
  @@map("penalties")
}

/// Validator rewards
model Reward {
  id         Int      @id @default(autoincrement())
  startBlock Int      @map("start_block")
  stopBlock  Int      @map("stop_block")
  hotkey     String
  points     Float
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([hotkey], name: "idx_rewards_hotkey")
  @@index([startBlock, stopBlock], name: "idx_rewards_blocks")
  @@map("rewards")
}

/// Blacklisted validator hotkeys
model BlacklistedHotkey {
  hotkey    String   @id
  reason    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("blacklisted_hotkeys")
}

/// Historical TAO/USD price data
model TaoUsdPrice {
  id                    Int      @id @default(autoincrement())
  taoPrice              Float    @map("tao_price")
  date                  DateTime @default(now()) @db.Timestamptz
  
  // Additional market data (optional - populated when using CoinGecko)
  marketCap             Float?   @map("market_cap")
  volume24h             Float?   @map("volume_24h")
  priceChange24h        Float?   @map("price_change_24h")
  marketCapChange24h    Float?   @map("market_cap_change_24h")
  priceChange7d         Float?   @map("price_change_7d")
  priceChange30d        Float?   @map("price_change_30d")
  source                String?  // "coingecko" or "taostats"

  @@index([date], name: "idx_tao_usd_price_date")
  @@map("tao_usd_price")
}

// ============================================================================
// Telegram Models
// ============================================================================

/// Telegram groups being monitored
model TelegramGroup {
  id          String             @id @default(cuid())
  telegramId  BigInt             @unique @map("telegram_id")
  title       String
  isMonitored Boolean            @default(false) @map("is_monitored")
  isMuted     Boolean            @default(false) @map("is_muted")
  mutedUntil  DateTime?          @map("muted_until")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  messages    TelegramMessage[]

  @@index([telegramId], name: "idx_telegram_groups_telegram_id")
  @@index([isMonitored], name: "idx_telegram_groups_monitored")
  @@map("telegram_groups")
}

/// Telegram messages
model TelegramMessage {
  id             String                    @id @default(cuid())
  telegramId     BigInt                    @unique @map("telegram_id")
  groupId        String                    @map("group_id")
  senderId       BigInt                    @map("sender_id")
  senderUsername String?                   @map("sender_username")
  senderName     String                    @map("sender_name")
  content        String
  replyToId      BigInt?                   @map("reply_to_id")
  createdAt      DateTime                  @default(now()) @map("created_at")
  
  // Relations
  group          TelegramGroup             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  scorings       TelegramScoring[]
  analysis       TelegramMessageAnalysis?

  @@index([groupId], name: "idx_telegram_messages_group")
  @@index([createdAt], name: "idx_telegram_messages_created")
  @@index([replyToId], name: "idx_telegram_messages_reply_to")
  @@index([senderId], name: "idx_telegram_messages_sender")
  @@map("telegram_messages")
}

/// Telegram message analysis/classification results
model TelegramMessageAnalysis {
  id                  Int              @id @default(autoincrement())
  messageId           String           @unique @map("message_id")
  
  // Sentiment analysis
  sentiment           String?          // very_bullish, bullish, neutral, bearish, very_bearish
  
  // Subnet classification (legacy — kept for backward compatibility with existing data)
  subnetId            Int?             @map("subnet_id")
  subnetName          String?          @map("subnet_name")

  // Asset classification (new — replaces subnet classification)
  assetId             Int?             @map("asset_id")
  assetSymbol         String?          @map("asset_symbol")
  
  // Content analysis
  contentType         String?          @map("content_type")
  technicalQuality    String?          @map("technical_quality")
  marketAnalysis      String?          @map("market_analysis")
  impactPotential     String?          @map("impact_potential")
  relevanceConfidence String?          @map("relevance_confidence")
  
  // Full analysis data (JSON blob)
  analysisData        Json?            @map("analysis_data") @db.JsonB

  // Miner attribution
  minerHotkey         String?          @map("miner_hotkey")

  // Timestamps
  analyzedAt          DateTime         @default(now()) @map("analyzed_at")
  updatedAt           DateTime         @default(now()) @updatedAt @map("updated_at")

  // Relations
  message             TelegramMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([sentiment], name: "idx_telegram_analysis_sentiment")
  @@index([subnetId], name: "idx_telegram_analysis_subnet")
  @@index([assetId], name: "idx_telegram_analysis_asset")
  @@index([analyzedAt], name: "idx_telegram_analysis_analyzed_at")
  @@map("telegram_message_analysis")
}

/// Scoring records for telegram message validation
model TelegramScoring {
  id              Int              @id @default(autoincrement())
  messageId       String           @map("message_id")
  status          String           @default("pending") // pending, in_progress, completed
  startTime       DateTime?        @map("start_time")
  validatorHotkey String?          @map("validator_hotkey")
  score           Float?
  epoch           Int?             @map("epoch")
  minerHotkey     String?          @map("miner_hotkey")
  createdAt       DateTime         @default(now()) @map("created_at")

  // Relations
  message         TelegramMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId], name: "idx_telegram_scoring_message")
  @@index([status], name: "idx_telegram_scoring_status")
  @@index([validatorHotkey], name: "idx_telegram_scoring_validator")
  @@index([status, startTime], name: "idx_telegram_scoring_status_start_time")
  @@map("telegram_scoring")
}

// ============================================================================
// News Article Models
// ============================================================================

/// News articles from RSS feeds and CC-NEWS WARC archives
model NewsArticle {
  id          Int       @id @default(autoincrement())
  url         String    @unique
  title       String
  summary     String?
  content     String?
  rawHtml     String?   @map("raw_html")
  published   DateTime? @db.Timestamptz
  source      String
  topic       String?
  extra       Json?     @db.JsonB
  ruleTag     String?   @map("rule_tag")
  sourceType  String    @default("rss") @map("source_type")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  scorings       NewsArticleScoring[]
  analysis       NewsArticleAnalysis?
  eventLinks     EventArticle[]
  narrativeLinks NarrativeArticle[]

  @@index([source], name: "idx_news_articles_source")
  @@index([published], name: "idx_news_articles_published")
  @@index([createdAt], name: "idx_news_articles_created")
  @@index([sourceType], name: "idx_news_articles_source_type")
  @@map("news_articles")
}

/// News article analysis/classification results
model NewsArticleAnalysis {
  id                  Int          @id @default(autoincrement())
  articleId           Int          @unique @map("article_id")
  sentiment           String?
  sectorId            Int?         @map("sector_id")
  sectorSymbol        String?      @map("sector_symbol")
  contentType         String?      @map("content_type")
  technicalQuality    String?      @map("technical_quality")
  marketAnalysis      String?      @map("market_analysis")
  impactPotential     String?      @map("impact_potential")
  relevanceConfidence String?      @map("relevance_confidence")
  mentionedAssets     Json?        @map("mentioned_assets") @db.JsonB
  analysisData        Json?        @map("analysis_data") @db.JsonB
  minerHotkey         String?      @map("miner_hotkey")
  analyzedAt          DateTime     @default(now()) @map("analyzed_at") @db.Timestamptz
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  article             NewsArticle  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  // V2 ArticleIntelligence indexed fields
  impactLevel         String?      @map("impact_level")
  factualConfidence   String?      @map("factual_confidence")
  eventType           String?      @map("event_type")
  eventDate           DateTime?    @map("event_date") @db.Date
  contentHash         String?      @map("content_hash")
  primaryGeo          String?      @map("primary_geo")
  overallSentimentScore Float?     @map("overall_sentiment_score")
  narrativeEmbedding    Float[]    @default([]) @map("narrative_embedding")

  @@index([sentiment], name: "idx_news_analysis_sentiment")
  @@index([sectorId], name: "idx_news_analysis_sector")
  @@index([analyzedAt], name: "idx_news_analysis_analyzed_at")
  @@index([eventType], name: "idx_news_analysis_event_type")
  @@index([eventDate], name: "idx_news_analysis_event_date")
  @@index([contentHash], name: "idx_news_analysis_content_hash")
  @@index([impactLevel], name: "idx_news_analysis_impact")
  @@map("news_article_analysis")
}

/// Scoring records for news article validation
model NewsArticleScoring {
  id              Int          @id @default(autoincrement())
  articleId       Int          @map("article_id")
  status          String       @default("pending")
  startTime       DateTime?    @map("start_time") @db.Timestamptz
  validatorHotkey String?      @map("validator_hotkey")
  score           Float?
  epoch           Int?         @map("epoch")
  minerHotkey     String?      @map("miner_hotkey")
  // Denormalized copy of news_articles.title, populated at insert. Lets the
  // unscored-article title dedup probe an index on this table instead of a
  // whole-table anti-join over news_articles (the /articles/unscored pool
  // exhaustion). Article titles are immutable post-ingest, so this never drifts.
  title           String?
  // Denormalized copy of news_articles.published, same immutability. Lets path A
  // order the pending pool by published via an index (status, published) instead of
  // sorting the whole pool before LIMIT — so path A halts at 150 regardless of how
  // large pending grows (required once ccnews routes all inflow into pending).
  published       DateTime?    @db.Timestamptz
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz

  article         NewsArticle  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId], name: "idx_news_scoring_article")
  @@index([status], name: "idx_news_scoring_status")
  @@index([validatorHotkey], name: "idx_news_scoring_validator")
  @@index([status, startTime], name: "idx_news_scoring_status_start_time")
  // Supports the title dedup in get_unscored_articles: path B probes title,
  // path A probes (title, status). Created CONCURRENTLY out-of-band — see the
  // migration runbook. NOTE: kept in sync with the DB index built concurrently.
  @@index([title, status], name: "idx_news_scoring_title_status")
  // Serves path A's pending pick in published order without a sort (index scan
  // halts at LIMIT). Built CONCURRENTLY as (status, published DESC, id DESC).
  @@index([status, published, id], name: "idx_news_scoring_status_published")
  @@map("news_article_scoring")
}

// ============================================================================
// Event & Narrative System (ArticleIntelligence V2)
// ============================================================================

/// Canonical events — groups of articles about the same real-world event
model Event {
  id              Int       @id @default(autoincrement())
  fingerprint     String    @unique
  eventType       String    @map("event_type")
  canonicalTitle  String    @map("canonical_title")
  eventDate       DateTime? @map("event_date") @db.Date
  sectorId        Int?      @map("sector_id")
  sectorSymbol    String?   @map("sector_symbol")
  articleCount    Int       @default(1) @map("article_count")
  sentiment       String?
  impactPotential String?   @map("impact_potential")
  entities        Json?     @db.JsonB
  summary         String?
  titleEmbedding  Float[]   @default([]) @map("title_embedding")
  firstSeenAt     DateTime  @default(now()) @map("first_seen_at") @db.Timestamptz
  lastArticleAt   DateTime  @default(now()) @map("last_article_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  articles        EventArticle[]
  narrativeLinks  EventNarrative[]

  @@index([eventType], name: "idx_events_type")
  @@index([eventDate], name: "idx_events_date")
  @@index([sectorId], name: "idx_events_sector")
  @@index([lastArticleAt], name: "idx_events_last_article")
  @@map("events")
}

/// Join table: articles <-> events (many-to-many)
model EventArticle {
  id        Int      @id @default(autoincrement())
  eventId   Int      @map("event_id")
  articleId Int      @map("article_id")
  role      String   @default("reporting")
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamptz

  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([eventId, articleId])
  @@index([eventId], name: "idx_event_articles_event")
  @@index([articleId], name: "idx_event_articles_article")
  @@map("event_articles")
}

/// Market narratives — long-running themes across many articles/events
model Narrative {
  id              Int       @id @default(autoincrement())
  slug            String    @unique
  name            String
  description     String?
  keywords        Json      @db.JsonB
  sectorIds       Json?     @map("sector_ids") @db.JsonB
  sentimentBias   String?   @map("sentiment_bias")
  phase           String    @default("emerging")
  articleCount    Int       @default(0) @map("article_count")
  eventCount      Int       @default(0) @map("event_count")
  sentimentScore  Float?    @map("sentiment_score")
  momentum        Float?
  source          String    @default("seed")
  embedding       Float[]   @default([])
  embeddingModel  String?   @map("embedding_model")
  startDate       DateTime? @map("start_date") @db.Date
  lastArticleAt   DateTime? @map("last_article_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  articleLinks    NarrativeArticle[]
  eventLinks      EventNarrative[]

  @@index([phase], name: "idx_narratives_phase")
  @@index([lastArticleAt], name: "idx_narratives_last_article")
  @@map("narratives")
}

/// Join table: articles <-> narratives
model NarrativeArticle {
  id             Int       @id @default(autoincrement())
  narrativeId    Int       @map("narrative_id")
  articleId      Int       @map("article_id")
  confidence     Float     @default(1.0)
  matchedKeyword String?   @map("matched_keyword")
  addedAt        DateTime  @default(now()) @map("added_at") @db.Timestamptz

  narrative      Narrative   @relation(fields: [narrativeId], references: [id], onDelete: Cascade)
  article        NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([narrativeId, articleId])
  @@index([narrativeId], name: "idx_narrative_articles_narrative")
  @@index([articleId], name: "idx_narrative_articles_article")
  @@map("narrative_articles")
}

/// Join table: events <-> narratives
model EventNarrative {
  id           Int       @id @default(autoincrement())
  eventId      Int       @map("event_id")
  narrativeId  Int       @map("narrative_id")
  addedAt      DateTime  @default(now()) @map("added_at") @db.Timestamptz

  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  narrative    Narrative @relation(fields: [narrativeId], references: [id], onDelete: Cascade)

  @@unique([eventId, narrativeId])
  @@index([eventId], name: "idx_event_narratives_event")
  @@index([narrativeId], name: "idx_event_narratives_narrative")
  @@map("event_narratives")
}

/// Tracks daily narrative intensity for time-series charting
model NarrativeIntensity {
  id            Int      @id @default(autoincrement())
  narrativeId   Int      @map("narrative_id")
  date          DateTime @db.Date
  articleCount  Int      @default(0) @map("article_count")
  avgSentiment  Float?   @map("avg_sentiment")
  sourceCount   Int      @default(0) @map("source_count")

  @@unique([narrativeId, date])
  @@index([narrativeId], name: "idx_narrative_intensity_narrative")
  @@index([date], name: "idx_narrative_intensity_date")
  @@map("narrative_intensity")
}

/// Candidate narratives waiting for auto-discovery threshold
model NarrativeCandidate {
  id            Int      @id @default(autoincrement())
  keyword       String   @unique
  articleCount  Int      @default(1) @map("article_count")
  sourceCount   Int      @default(1) @map("source_count")
  firstSeenAt   DateTime @default(now()) @map("first_seen_at") @db.Timestamptz
  lastSeenAt    DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  promoted      Boolean  @default(false)
  embedding     Float[]  @default([])

  @@index([keyword], name: "idx_narrative_candidates_keyword")
  @@index([articleCount], name: "idx_narrative_candidates_count")
  @@map("narrative_candidates")
}

/// Canonical per-item scoring paper trail. One row per (resource, validator, epoch).
model ScoreVerdict {
  id                Int      @id @default(autoincrement())
  resourceType      String   @map("resource_type")
  resourceId        String   @map("resource_id")
  epoch             Int
  validatorHotkey   String   @map("validator_hotkey")
  minerHotkey       String   @map("miner_hotkey")
  minerSignature    String   @map("miner_signature")
  minerAnalysisHash String   @map("miner_analysis_hash")
  validatorVerdict  String   @map("validator_verdict")
  categoricalKey    String   @map("categorical_key")
  pointsAwarded     Float    @map("points_awarded")
  isAudit           Boolean  @default(false) @map("is_audit")
  auditGroupId      String?  @map("audit_group_id")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([resourceType, resourceId, validatorHotkey, epoch], name: "uq_score_verdict_item")
  @@index([epoch, validatorHotkey], name: "idx_score_verdict_epoch_validator")
  @@index([auditGroupId], name: "idx_score_verdict_audit_group")
  @@map("score_verdict")
}

/// Signed per-(validator, epoch) snapshot — the broadcast payload.
model Attestation {
  id              Int      @id @default(autoincrement())
  validatorHotkey String   @map("validator_hotkey")
  epoch           Int
  perMinerPoints  Json     @map("per_miner_points")
  totalPoints     Float    @map("total_points")
  merkleRoot      String   @map("merkle_root")
  signature       String
  issuedAt        DateTime @default(now()) @map("issued_at") @db.Timestamptz

  @@unique([validatorHotkey, epoch], name: "uq_attestation_validator_epoch")
  @@map("attestation")
}

/// Receiver-flagged discrepancy; drives 2+ report consensus → blacklist.
model BroadcastReport {
  id             Int      @id @default(autoincrement())
  reporterHotkey String   @map("reporter_hotkey")
  accusedHotkey  String   @map("accused_hotkey")
  epoch          Int
  reason         String
  evidence       Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([reporterHotkey, accusedHotkey, epoch, reason], name: "uq_broadcast_report")
  @@index([accusedHotkey, epoch], name: "idx_broadcast_report_accused")
  @@map("broadcast_report")
}

/// Display-only penalty attribution for the miner dashboard. DECOUPLED from the
/// consensus pipeline by design: this table is never read by get_attestation,
/// get_verdicts, write_verdict, or merkle_root, and carries no signatures, hashes,
/// or points. It exists purely to explain to a miner why a penalty happened. The
/// authoritative number already reaches the miner (signed) via the Score synapse.
/// Do NOT fold this into score_verdict or any attestation/Merkle path.
model PenaltyDetail {
  id              Int      @id @default(autoincrement())
  minerHotkey     String   @map("miner_hotkey")
  validatorHotkey String   @map("validator_hotkey")
  epoch           Int
  resourceType    String   @map("resource_type")
  resourceId      String   @map("resource_id")
  cause           String // classification_mismatch | timeout | missing_classification | needs_update
  failedFields    Json?    @map("failed_fields")
  minerValues     Json?    @map("miner_values")
  validatorVals   Json?    @map("validator_values")
  postPreview     String?  @map("post_preview")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([minerHotkey, epoch], name: "idx_penalty_detail_miner_epoch")
  @@map("penalty_detail")
}
