# Block-based Rate Limiting Configuration
# Number of blocks per rate limit window (default: 100 blocks, ~20 minutes at 12s per block)
BLOCKS_PER_WINDOW=100
# Maximum submissions per miner per block window (default: 5)
MAX_SUBMISSION_RATE=5
# Number of submissions to assign per validator per request (default: 5)
VALIDATIONS_PER_REQUEST=5
# Average seconds per Bittensor block (default: 12.0, configurable for accuracy)
SECONDS_PER_BLOCK=12.0

# Validation Configuration
# Probability of a submission being selected for validation (default: 0.99 = 99%)
VALIDATION_PROBABILITY=0.99

VALIDATION_BACKEND=twitterapi

# X/Twitter API Configuration (required for tweet validation)
# X API bearer token (used by x_validation.py)
X_BEARER_TOKEN=
# TwitterAPI.io API key (used by twitterapi_validation.py as fallback)
TWITTER_API_IO_KEY=

# PostgreSQL Database Configuration
# Option 1: Use DATABASE_URL (full connection string, takes precedence over individual components)
# DATABASE_URL=postgresql://user:password@host:port/dbname
# Option 2: Use individual components (if DATABASE_URL is not set)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Bittensor Network Configuration
# Network to connect to: "test" or "mainnet" (default: "test")
BT_NETWORK=finney
# Subnet UID (default: 76)
SUBNET_UID=45

# Authentication Configuration
# Enable authentication (default: true)
AUTH_ENABLED=true
# Signature timeout in seconds (default: 300 = 5 minutes)
AUTH_SIGNATURE_TIMEOUT=300
# Comma-separated list of allowed hotkeys (optional, overrides metagraph whitelist)
# ALLOWED_HOTKEYS=hotkey1,hotkey2,hotkey3

# Blacklisted miner hotkey prefixes (timed out due to poor submissions)
# Comma-separated list of prefixes
BLACKLISTED_HOTKEY_PREFIXES=

# Crypto Asset Taxonomy Gate
# Set to "true" to serve search-polled crypto tweets (BTC, ETH, SOL, TAO) to validators.
# When "false" (default), only WebSocket-ingested tweets are served.
SERVE_CRYPTO_TWEETS=false

# News Articles Gate
# Set to "true" to serve RSS-ingested news articles to validators.
# When "false" (default), the /articles/* endpoints return empty results.
SERVE_NEWS_ARTICLES=false

# Set to "true" to include each article's raw HTML in /articles/unscored so
# miners/validators can run trafilatura on the real DOM (analyzer-side
# re-extraction). OFF by default: raw HTML is large and rides in the miner
# synapse. Content is already trafilatura-cleaned at ingest, so leaving this
# off loses no quality; enable only if you want analyzer-side re-extraction.
SERVE_RAW_HTML=false

# Scoring lease TTL in seconds (default: 900 = 15 minutes)
# Leases older than this are reclaimed and made available to other validators.
SCORING_LEASE_TTL_SECONDS=900

# TAO Price History Configuration
# Refresh interval in seconds (default: 900 = 15 minutes)
TAO_PRICE_HISTORY_REFRESH_SECONDS=900
# TaoStats API key (used by default)
TAOSTATS_API_KEY=
# Set to "true" to use CoinGecko instead of TaoStats
USE_COINGECKO=false
# CoinGecko API key (required if USE_COINGECKO=true)
COINGECKO_API_KEY=
# Optional separate database URL for price data
PRICE_DATABASE_URL=
# --- Verifiable validator points ---
# Generate with: python scripts/gen_attestation_key.py
API_ATTESTATION_PRIVKEY=          # hex sr25519 seed (secret; signs attestations)
MAX_POINTS_PER_ITEM=1             # per-verdict ceiling
# Prod-safe defaults below are NO-OPS — enable deliberately for a controlled test only.
MAX_OUTSTANDING_LEASES=0          # per-validator in-progress lease cap; 0 = unlimited (no throttle)
AUDIT_OVERLAP_RATE=0             # fraction of leases silently re-issued as audit overlaps; 0 = off
REPORT_CONSENSUS_THRESHOLD=2      # distinct reporters that constitute consensus
REPORTS_AUTO_BLACKLIST=false      # false = alarm-only on consensus; true = auto-blacklist accused
VERDICT_ALLOWLIST_HOTKEYS=        # CSV of validator hotkeys; empty = no restriction (all validators)
